{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://farewell-social-backend.onrender.com/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://farewell-social-backend.onrender.com/uploads/$1"
        },
        {
            "source": "/((?!api/|uploads/).*)",
            "destination": "/index.html"
        }
    ]
}